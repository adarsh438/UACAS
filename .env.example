# UACAS Enterprise Configuration

# --- DATABASE ---
# For local dev:    SQLite  → "file:./dev.db"
# For Vercel/cloud: Postgres → "postgresql://user:pass@host:5432/db?schema=public"
# NOTE: Vercel has NO persistent filesystem — SQLite will NOT work on Vercel.
# Use a cloud Postgres service (Neon, Supabase, Railway, Render Postgres).
DATABASE_URL="file:./dev.db"

# --- AI & ANALYTICS ---
# Get your key from https://aistudio.google.com/
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- SECURITY ---
# JWT secret for signing auth tokens (must be ≥32 chars in production)
JWT_SECRET="ENTERPRISE_SECRET_KEY_CHANGE_ME_TO_SOMETHING_SECURE_AND_LONG_0123456789"
# Legacy alias (AUTH_SECRET is also accepted):
AUTH_SECRET="ENTERPRISE_SECRET_KEY_CHANGE_ME_TO_SOMETHING_SECURE_AND_LONG_0123456789"

# --- APPLICATION ---
# The public URL of the deployed app (used in report links, Excel exports, etc.)
APP_URL="http://localhost:3000"
# Set this to your production domain so report URLs are not hardcoded to localhost
PUBLIC_BASE_URL="https://yourdomain.com"
NODE_ENV="production"
