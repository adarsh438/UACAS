# UACAS Enterprise Configuration

# --- DATABASE ---
# For local dev use SQLite: "file:./dev.db"
# For production use PostgreSQL: "postgresql://johndoe:mypassword@localhost:5432/mydb?schema=public"
DATABASE_URL="file:./dev.db"

# --- AI & ANALYTICS ---
# Get your key from https://aistudio.google.com/
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# --- SECURITY ---
# A random secret string for JWT signing (must be at least 32 characters in production)
AUTH_SECRET="ENTERPRISE_SECRET_KEY_CHANGE_ME_TO_SOMETHING_SECURE_AND_LONG"

# --- APPLICATION ---
# The public URL of the deployed app (used in report links, Excel exports, etc.)
APP_URL="http://localhost:3000"
# Set this to your production domain so report URLs are not hardcoded to localhost
PUBLIC_BASE_URL="https://yourdomain.com"
NODE_ENV="production"
